# API Base URL — sin trailing slash
VITE_API_URL=http://localhost:5000

# Nombre de la aplicación
VITE_APP_NAME=Chipo

# Tiempo de vida del access token en ms (para refresh proactivo)
VITE_ACCESS_TOKEN_EXPIRY_MS=900000

# Habilitar React Query DevTools (true en dev, false en prod)
VITE_ENABLE_DEVTOOLS=true
